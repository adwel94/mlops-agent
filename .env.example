# 프로젝트 비밀키/설정 템플릿. 이 파일을 복사해서 `.env` 를 만들고 값을 채운다:
#     cp .env.example .env      (WSL/bash)   |   Copy-Item .env.example .env   (PowerShell)
# `.env` 는 gitignore 대상(커밋 안 됨). 엔트리포인트가 scripts.env_config.load_env() 로 읽음.
# 셸에 이미 export 된 값이 .env 보다 우선한다.

# ── 지금 필요 (RunPod 스킬) ────────────────────────────────────────────────
# RunPod 콘솔 → Settings → API Keys 에서 발급.
RUNPOD_API_KEY=

# ── 학습 파이프라인 (앞으로) ──────────────────────────────────────────────
# HuggingFace 토큰 (게이트 모델 다운로드 / 체크포인트 업로드 시).
HF_TOKEN=

# Weights & Biases (학습 로깅).
WANDB_API_KEY=
WANDB_PROJECT=maniskill-gr00t
WANDB_ENTITY=

# Discord 알림 (채널별 webhook URL — utils/discord.py 의 DiscordChannel 과 1:1).
#   RUNPOD_WEBHOOK_URL       : 파드/인프라/과금 (생성·자가종료·종료실패 경보) — 저빈도/고중요
#   PIPELINE_WEBHOOK_URL     : 학습 파이프라인 (시작·진행바·완료·업로드·실패) — 진행 추적
#   STDOUT_WEBHOOK_URL       : 파드 raw stdout 스트림 (부팅~학습~실패) — 에이전트가 봇 토큰으로 읽음
#   AI_REPORTING_WEBHOOK_URL : AI(에이전트)가 push 하는 자연어 추세 리포트 — 파드-push 가 아니라
#                              에이전트가 ai_report.py 로 보냄(폴링 주기마다 해석·판단 코멘트).
#   BOOT_TIMING_WEBHOOK_URL  : 파드 부팅 계측 — bootstrap(apt/clone/uv_sync) 완료 시 파드가
#                              BOOT_PROFILE 한 줄(파싱 가능) 전송. 같은 task 의 부팅 시간을
#                              파드/머신 간 비교(예: "이번 머신 느림")하는 영속 로그.
# 한 채널로 합치려면 같은 URL 을 여러 칸에 넣으면 됨.
RUNPOD_WEBHOOK_URL=
PIPELINE_WEBHOOK_URL=
STDOUT_WEBHOOK_URL=
AI_REPORTING_WEBHOOK_URL=
BOOT_TIMING_WEBHOOK_URL=

# Discord 봇 토큰 — STDOUT 채널을 *읽기* 위함(read_logs.py, 로컬 모니터링 전용).
# 파드로는 전달하지 않음. 봇은 서버 멤버 + 그 채널 View Channel/Read Message History 권한 필요.
DISCORD_BOT_TOKEN=

# Prefect (오케스트레이션). self-host 면 PREFECT_API_URL, Cloud 면 둘 다.
PREFECT_API_URL=
PREFECT_API_KEY=

# ── 외부 종료 Worker (cloud/reaper — Cloudflare Worker) ────────────────────
# 파드는 자기를 RunPod API로 직접 못 죽인다(파드→RunPod 호출은 랜덤 403). 대신 RunPod
# 밖에서 100% 도는 이 Worker 에게 "죽여줘"를 보내고, Worker 가 실제 DELETE 를 한다.
#   WORKER_TERMINATE_URL : 배포된 Worker 의 /terminate 주소 (wrangler deploy 후 받음).
#                          예: https://runpod-reaper.<계정>.workers.dev/terminate
#   POD_PING_SECRET      : 파드↔Worker 공유 비밀. 공개 /terminate 엔드포인트에 아무나
#                          POST 해 파드를 죽이지 못하게 막는 자물쇠. 우리가 만드는 아무 긴
#                          랜덤 문자열(예: `openssl rand -hex 32`). **Worker 시크릿과 동일값**
#                          (wrangler secret put POD_PING_SECRET) 이어야 함.
WORKER_TERMINATE_URL=
POD_PING_SECRET=

# ── 선택: 학습 파라미터 오버라이드 (보통 안 건드림) ────────────────────────
# 아래는 비밀이 아니라 *튜닝값*. 평소엔 launch_train.py 의 CLI/기본값이 런마다
# 파드 env 로 주입하므로 여기 비워둔다. .env 에 값을 넣으면 **모든 런의 기본**이
# 바뀐다(셸 export 가 .env 보다 우선). 키는 options.py 의 필드명 대문자(FIELD→FIELD).
# 한 런만 다르게 하려면 .env 말고 launch_train 인자로 주는 게 안전.
#
#   DISCORD_HOOK_STEPS=100      # N 스텝마다 PIPELINE 진행바 1회 (기본 100)
#   MAX_STEPS=20000             # 총 학습 스텝
#   GLOBAL_BATCH_SIZE=16        # 단일 GPU 합산 배치
#   LEARNING_RATE=1e-4          # 학습률 (코사인 감쇠)
#   SAVE_STEPS=                 # 체크포인트 저장 간격 (<= MAX_STEPS)
#   SAVE_TOTAL_LIMIT=1          # 유지할 체크포인트 수 (3B≈29GB → 누적 주의)
#   EPISODE_SAMPLING_RATE=1.0   # 데이터셋 에피소드 사용 비율
#   USE_WANDB=true              # W&B 로깅 (WANDB_API_KEY 없으면 자동 false)
#   TUNE_LLM / TUNE_VISUAL      # true 면 전체 튜닝(--full 과 동등, A100 권장)
#
# 파드 내부 경로/진단용(거의 안 씀): GR00T_DIR, DL_DIR, LOGURU_LEVEL=INFO,
# PROBE_DATASET / PROBE_GPU / PROBE_CLOUD (cloud/serve/probe_dl 진단 스크립트).
# HF_DATASET_REPO·HF_OUTPUT_REPO·HF_OUTPUT_TAG 등은 launch_train 이 런마다 자동 주입.
