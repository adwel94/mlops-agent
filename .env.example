# 프로젝트 비밀키/설정 템플릿. 이 파일을 복사해서 `.env` 를 만들고 값을 채운다:
#     cp .env.example .env      (WSL/bash)   |   Copy-Item .env.example .env   (PowerShell)
# `.env` 는 gitignore 대상(커밋 안 됨). 엔트리포인트가 scripts.env_config.load_env() 로 읽음.
# 셸에 이미 export 된 값이 .env 보다 우선한다.

# ── 지금 필요 (RunPod 스킬) ────────────────────────────────────────────────
# RunPod 콘솔 → Settings → API Keys 에서 발급.
RUNPOD_API_KEY=

# ── 학습 파이프라인 (앞으로) ──────────────────────────────────────────────
# HuggingFace 토큰 (게이트 모델 다운로드 / 체크포인트 업로드 시).
HF_TOKEN=

# Weights & Biases (학습 로깅).
WANDB_API_KEY=
WANDB_PROJECT=maniskill-gr00t
WANDB_ENTITY=

# Discord 알림 (채널별 webhook URL — utils/discord.py 의 DiscordChannel 과 1:1).
#   RUNPOD_WEBHOOK_URL   : 파드/인프라/과금 (생성·자가종료·종료실패 경보) — 저빈도/고중요
#   PIPELINE_WEBHOOK_URL : 학습 파이프라인 (시작·진행바·완료·업로드·실패) — 진행 추적
#   STDOUT_WEBHOOK_URL   : 파드 raw stdout 스트림 (부팅~학습~실패) — 에이전트가 봇 토큰으로 읽음
# 한 채널로 합치려면 같은 URL 을 둘 다(셋 다)에 넣으면 됨.
RUNPOD_WEBHOOK_URL=
PIPELINE_WEBHOOK_URL=
STDOUT_WEBHOOK_URL=

# Discord 봇 토큰 — STDOUT 채널을 *읽기* 위함(read_logs.py, 로컬 모니터링 전용).
# 파드로는 전달하지 않음. 봇은 서버 멤버 + 그 채널 View Channel/Read Message History 권한 필요.
DISCORD_BOT_TOKEN=

# Prefect (오케스트레이션). self-host 면 PREFECT_API_URL, Cloud 면 둘 다.
PREFECT_API_URL=
PREFECT_API_KEY=

# ── 외부 종료 Worker (cloud/reaper — Cloudflare Worker) ────────────────────
# 파드는 자기를 RunPod API로 직접 못 죽인다(파드→RunPod 호출은 랜덤 403). 대신 RunPod
# 밖에서 100% 도는 이 Worker 에게 "죽여줘"를 보내고, Worker 가 실제 DELETE 를 한다.
#   WORKER_TERMINATE_URL : 배포된 Worker 의 /terminate 주소 (wrangler deploy 후 받음).
#                          예: https://runpod-reaper.<계정>.workers.dev/terminate
#   POD_PING_SECRET      : 파드↔Worker 공유 비밀. 공개 /terminate 엔드포인트에 아무나
#                          POST 해 파드를 죽이지 못하게 막는 자물쇠. 우리가 만드는 아무 긴
#                          랜덤 문자열(예: `openssl rand -hex 32`). **Worker 시크릿과 동일값**
#                          (wrangler secret put POD_PING_SECRET) 이어야 함.
WORKER_TERMINATE_URL=
POD_PING_SECRET=
